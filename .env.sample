## SHOPIFY
NEXT_PUBLIC_LATEST_PRODUCTS_HANDLE=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

## Recipe product variant and selling plan IDs (turkey, lamb, pancreatic)
# Turkey
NEXT_PUBLIC_TURKEY_VARIANT_ID=gid://shopify/ProductVariant/47241921626333
NEXT_PUBLIC_TURKEY_SELLING_PLAN_WEEKLY=gid://shopify/SellingPlan/6280184029
NEXT_PUBLIC_TURKEY_SELLING_PLAN_BIWEEKLY=gid://shopify/SellingPlan/6280216797
# Lamb
NEXT_PUBLIC_LAMB_VARIANT_ID=gid://shopify/ProductVariant/47241925918941
NEXT_PUBLIC_LAMB_SELLING_PLAN_WEEKLY=gid://shopify/SellingPlan/6280052957
NEXT_PUBLIC_LAMB_SELLING_PLAN_BIWEEKLY=gid://shopify/SellingPlan/6280085725
# Pancreatic
NEXT_PUBLIC_PANCREATIC_VARIANT_ID=gid://shopify/ProductVariant/47241926344925
NEXT_PUBLIC_PANCREATIC_SELLING_PLAN_WEEKLY=gid://shopify/SellingPlan/6280151261
NEXT_PUBLIC_PANCREATIC_SELLING_PLAN_BIWEEKLY=gid://shopify/SellingPlan/6280118493
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

## Google Tag Manager
# Required (e.g. GTM-K57RTZ79 for production)
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
# Optional: GTM environment params (Admin > Environments > Get Snippet)
# Leave empty for production (uses Live environment by default)
NEXT_PUBLIC_GTM_AUTH=
NEXT_PUBLIC_GTM_PREVIEW=

## DEV
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=rootstrapstore-dev.myshopify.com

## QA
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=shopify-case-study-git-qa-shopify-case-study-team.vercel.app

## SHOPIFY API VERSION
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-10

## CONTENTFUL
# Delivery API (app: fetch copy, rich text, quiz options, experts)
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_PREVIEW_ACCESS_TOKEN=
# Optional: override Contentful environment (staging | master). If unset, inferred from VERCEL_ENV.
# CONTENTFUL_ENVIRONMENT=staging
# Management API (scripts/syncEnJsonToContentful: create content types and entries)
CONTENTFUL_MANAGEMENT_TOKEN=

RECHARGE_ACCESS_TOKEN=
